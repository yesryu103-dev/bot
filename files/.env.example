# ==== Telegram ====
# Tạo bot qua @BotFather, lấy token
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Chat ID / channel ID để bot gửi tin (dùng @userinfobot hoặc getUpdates để lấy)
TELEGRAM_CHAT_ID=-1001234567890

# ==== Robinhood Chain RPC ====
# HTTP RPC - dùng để đọc token0/token1/decimals lúc start, và làm fallback polling nếu WS chết
RPC_URL=https://rpc.mainnet.chain.robinhood.com
CHAIN_ID=4663

# WebSocket RPC - BẮT BUỘC để bot nhận Swap event realtime (không delay theo poll interval)
# Lấy free tại alchemy.com -> tạo app chọn network "Robinhood Chain Mainnet" -> copy endpoint HTTPS
# rồi đổi "https://" thành "wss://" là ra URL WS (dùng chung 1 API key)
# Ví dụ: wss://robinhood-mainnet.g.alchemy.com/v2/<api-key>
# Nếu để trống, bot sẽ tự chạy chế độ polling HTTP (chậm hơn, dùng RPC_URL ở trên)
RPC_WS_URL=wss://robinhood-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# ==== Pool cần theo dõi (REPE/WETH Uniswap v3 trên Robinhood) ====
POOL_ADDRESS=0xB541C2936982DD5c4090783d8F395d3e613c8016

# Token muốn track buy/sell theo (token "chính", vd REPE) - còn lại coi là token định giá (WETH)
BASE_TOKEN_ADDRESS=0x5266eeafF092D6136AB63D18B975A60a0Cc0C8f7
BASE_TOKEN_SYMBOL=REPE

QUOTE_TOKEN_ADDRESS=0x0Bd7D308f8E1639FAb988df18A8011f41EAcAD73
QUOTE_TOKEN_SYMBOL=WETH

# Ngưỡng lọc giao dịch nhỏ (tính theo quote token, vd 0 = báo hết, 0.01 = chỉ báo giao dịch >= 0.01 WETH)
MIN_QUOTE_AMOUNT=0

# Polling interval (ms) - block time Robinhood ~0.1s nên không cần quá nhanh, 3000ms là ổn cho public RPC
POLL_INTERVAL_MS=3000

# Link explorer để build link tx trong tin nhắn
EXPLORER_TX_BASE=https://robinhoodchain.blockscout.com/tx/
