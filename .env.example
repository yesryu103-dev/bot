TELEGRAM_BOT_TOKEN=123456:replace_me
# Telegram chat/group ID that may use the bot. Comma-separated for multiple chats.
# Private chat IDs are positive numbers. Group/supergroup IDs start with -100.
TELEGRAM_CHAT_ID=-1001234567890
BOT_TITLE=Treasure_tradingbot
BOT_TAGLINE=
# Social links removed from main panel (leave empty).
PROJECT_TELEGRAM_URL=
PROJECT_TWITTER_URL=
PROJECT_WEBSITE_URL=

# Robinhood REPE/WETH Uniswap v3 pair from Dexscreener:
PAIR_ADDRESS=0xb541c2936982dd5c4090783d8f395d3e613c8016
BASE_TOKEN_ADDRESS=0x5266eeaff092d6136ab63d18b975a60a0cc0c8f7
QUOTE_TOKEN_ADDRESS=0x0bd7d308f8e1639fab988df18a8011f41eacad73
BASE_SYMBOL=REPE
QUOTE_SYMBOL=WETH

POLL_SECONDS=3
MAX_ITEMS=200
MIN_USD=0
MIN_QUOTE_AMOUNT=1
# Only alert swaps newer than this many ms (realtime). Older txs are ignored.
MAX_ALERT_AGE_MS=90000
DRY_RUN=0
BACKFILL_ON_START=0
FETCH_TX_DETAILS=0

# Default 1 means base token out of pool = BUY, base token into pool = SELL.
BUY_WHEN_BASE_LEAVES_POOL=1

# Telegram trade buttons.
BUY_AMOUNTS_QUOTE=0.01,0.05,0.1,0.25
SELL_PERCENTS=25,50,70
ONE_TAP_TRADE=0

# Keep disabled until you configure a trading wallet.
TRADE_ENABLED=0
RPC_URL=https://rpc.mainnet.chain.robinhood.com
WALLET_PRIVATE_KEY=
WALLET_ADDRESS=
SWAP_ROUTER_ADDRESS=0xCaf681a66D020601342297493863E78C959E5cb2
QUOTER_ADDRESS=0x33e885ed0ec9bf04ecfb19341582aadcb4c8a9e7
UNISWAP_V3_FEE=10000
SLIPPAGE_BPS=200
POSITION_MANAGER_ADDRESS=0x73991a25c818bf1f1128deaab1492d45638de0d3
V3_FACTORY_ADDRESS=0x1f7d7550B1b028f7571E69A784071F0205FD2EfA
V2_FACTORY_ADDRESS=0x8bcEaA40B9AcdfAedF85AdF4FF01F5Ad6517937f
MULTICALL3_ADDRESS=0xcA11bde05977b3631167028862bE2a173976CA11
